    <svg class="d2" viewBox="0 0 300 300" fill="none"><circle cx="150" cy="150" r="140" stroke="#d4af37" stroke-width=".8"/><ellipse cx="150" cy="150" rx="70" ry="140" stroke="#d4af37" stroke-width=".8"/></svg>
