<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Accueil — Stromboli Caffé</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&display=swap" rel="stylesheet">
<style>

:root {
  --burgundy: #721c24;
  --dark: #1a090a;
  --deeper: #0e0508;
  --cream: #f9f6f0;
  --gold: #d4af37;
  --gold-light: #e9c46a;
  --white: #ffffff;
  --text: #2d2d2d;
  --sans: 'Plus Jakarta Sans', sans-serif;
  --serif: 'Playfair Display', serif;
  --ease: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
}

*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;-webkit-font-smoothing:antialiased}
html{scroll-behavior:smooth}
body{font-family:var(--sans);background:var(--cream);color:var(--text);overflow-x:hidden;line-height:1.6}
a{text-decoration:none;color:inherit}
button{font-family:var(--sans);cursor:pointer}
img{display:block;max-width:100%}

.site-header{position:fixed;top:0;left:0;width:100%;z-index:200;padding:20px 6%;display:flex;
  justify-content:space-between;align-items:center;transition:background .4s,backdrop-filter .4s}
.site-header.scrolled{background:rgba(26,9,10,.92);backdrop-filter:blur(18px);
  border-bottom:1px solid rgba(212,175,55,.12)}
.brand-logo{font-family:var(--serif);font-size:26px;font-weight:700;color:var(--white);letter-spacing:.5px}
.brand-logo span{color:var(--gold)}
.main-nav{background:rgba(255,255,255,.08);backdrop-filter:blur(12px);
  padding:8px 28px;border-radius:100px;border:1px solid rgba(255,255,255,.14);
  display:flex;gap:28px;align-items:center}
.nav-link{font-size:13px;font-weight:500;color:var(--white);opacity:.82;text-transform:capitalize;
  transition:var(--ease);padding:6px 2px;position:relative}
.nav-link::after{content:'';position:absolute;bottom:0;left:0;width:0;height:1px;
  background:var(--gold);transition:width .3s}
.nav-link:hover,.nav-link.active{opacity:1;color:var(--gold)}
.nav-link:hover::after,.nav-link.active::after{width:100%}
.nav-cta{background:var(--gold);color:var(--dark);padding:9px 22px;border-radius:100px;
  font-size:13px;font-weight:600;transition:var(--ease)}
.nav-cta:hover{background:var(--white);transform:translateY(-2px);box-shadow:0 8px 24px rgba(212,175,55,.3)}

.site-footer{background:var(--deeper);color:var(--white);padding:72px 6% 36px;border-top:1px solid rgba(255,255,255,.05)}
.footer-grid{max-width:1280px;margin:0 auto 56px;display:grid;grid-template-columns:1.6fr 1fr 1fr 1fr;gap:40px}
.footer-logo{font-family:var(--serif);font-size:22px;font-weight:700;color:var(--white);margin-bottom:12px}
.footer-logo span{color:var(--gold)}
.footer-brand p{font-size:13px;opacity:.55;max-width:260px;line-height:1.75;margin-bottom:20px}
.footer-socials{display:flex;gap:10px}
.footer-socials a{width:32px;height:32px;border:1px solid rgba(212,175,55,.25);border-radius:50%;
  display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,.45);
  transition:var(--ease)}
.footer-socials a:hover{border-color:var(--gold);color:var(--gold)}
.footer-col h5{font-size:13px;font-weight:600;color:var(--gold);letter-spacing:.1em;text-transform:uppercase;margin-bottom:20px}
.footer-links{list-style:none}
.footer-links li{margin-bottom:10px}
.footer-links a{font-size:13px;opacity:.55;transition:var(--ease)}
.footer-links a:hover{opacity:1;color:var(--gold);padding-left:4px}
.footer-bottom{max-width:1280px;margin:0 auto;padding-top:32px;border-top:1px solid rgba(255,255,255,.05);
  display:flex;justify-content:space-between;align-items:center;font-size:12px;opacity:.4}
.policy-links{display:flex;gap:20px}
.policy-links a{color:var(--white);transition:opacity .2s}
.policy-links a:hover{opacity:.8}

.wa-fab{position:fixed;bottom:36px;right:36px;z-index:500;width:64px;height:64px;
  background:#25D366;border-radius:50%;display:flex;align-items:center;justify-content:center;
  color:#fff;box-shadow:0 8px 28px rgba(37,211,102,.45);
  transition:transform .3s,box-shadow .3s;animation:waPulse 2.8s ease-in-out infinite}
.wa-fab:hover{transform:scale(1.12);box-shadow:0 12px 36px rgba(37,211,102,.65)}
@keyframes waPulse{0%,100%{box-shadow:0 8px 28px rgba(37,211,102,.45)}
  50%{box-shadow:0 8px 36px rgba(37,211,102,.65),0 0 0 10px rgba(37,211,102,.08)}}

.reveal{opacity:0;transform:translateY(28px);transition:opacity .75s ease,transform .75s ease}
.reveal.vis{opacity:1;transform:translateY(0)}


/* HERO */
.hero-section{min-height:100vh;display:flex;align-items:center;
  padding:130px 6% 90px;position:relative;overflow:hidden;
  background:radial-gradient(ellipse 120% 80% at 60% 40%,var(--burgundy) 0%,var(--dark) 55%,var(--deeper) 100%)}

/* Decorative coffee-bean shapes */
.hero-decor{position:absolute;inset:0;pointer-events:none;overflow:hidden;z-index:0}
.hero-decor svg{position:absolute;opacity:.07}
.hero-decor .d1{top:-8%;right:8%;width:500px;animation:driftSlow 18s ease-in-out infinite}
.hero-decor .d2{bottom:-10%;left:5%;width:360px;animation:driftSlow 22s ease-in-out infinite reverse}
@keyframes driftSlow{0%,100%{transform:translateY(0) rotate(0deg)}50%{transform:translateY(-24px) rotate(8deg)}}

.hero-container{width:100%;max-width:1300px;margin:0 auto;display:grid;
  grid-template-columns:1fr 1.15fr;align-items:center;gap:60px;position:relative;z-index:2}

/* LEFT */
.hero-content{color:var(--white)}
.hero-badge{font-size:11px;text-transform:uppercase;letter-spacing:3px;color:var(--gold);
  font-weight:600;margin-bottom:18px;display:flex;align-items:center;gap:10px}
.hero-badge::before{content:'';width:28px;height:1px;background:var(--gold)}
.hero-title{font-family:var(--serif);font-size:clamp(2.8rem,5vw,4.4rem);line-height:1.12;
  font-weight:600;margin-bottom:22px;opacity:0;animation:fadeUp .9s .2s forwards}
.hero-title em{font-style:italic;font-weight:400;color:var(--gold)}
.hero-desc{font-size:15px;opacity:.72;margin-bottom:38px;max-width:460px;font-weight:300;line-height:1.8;
  opacity:0;animation:fadeUp .9s .38s forwards}
.hero-actions{display:flex;gap:14px;align-items:center;flex-wrap:wrap;
  opacity:0;animation:fadeUp .9s .54s forwards}
.btn-primary{display:inline-flex;align-items:center;gap:8px;background:var(--gold);color:var(--dark);
  padding:15px 32px;border-radius:100px;font-weight:600;font-size:14px;border:none;
  transition:var(--ease);box-shadow:0 8px 28px rgba(212,175,55,.3)}
.btn-primary:hover{background:var(--white);transform:translateY(-3px);box-shadow:0 14px 36px rgba(212,175,55,.25)}
.btn-secondary{display:inline-flex;align-items:center;background:rgba(255,255,255,.1);color:var(--white);
  padding:15px 28px;border-radius:100px;font-weight:500;font-size:14px;border:1px solid rgba(255,255,255,.18);
  transition:var(--ease)}
.btn-secondary:hover{background:rgba(255,255,255,.18);border-color:var(--gold);color:var(--gold)}
.hero-price-row{margin-top:32px;display:flex;align-items:center;gap:20px;
  opacity:0;animation:fadeUp .9s .7s forwards}
.hero-price{font-family:var(--serif);font-size:2.6rem;font-weight:700;color:var(--gold)}
.hero-price sub{font-size:.85rem;font-weight:400;color:rgba(255,255,255,.4);font-family:var(--sans)}
.hero-tag-pills{display:flex;gap:8px;flex-wrap:wrap;margin-top:18px;
  opacity:0;animation:fadeUp .9s .85s forwards}
.tag-pill{font-size:11px;font-weight:500;letter-spacing:.1em;text-transform:uppercase;
  padding:4px 12px;border:1px solid;border-radius:100px}

/* RIGHT — product showcase */
.product-showcase-container{display:flex;flex-direction:column;align-items:center;gap:32px;
  position:relative;z-index:2}

.main-product-stage{width:360px;height:460px;display:flex;align-items:center;justify-content:center;
  position:relative}

.product-glow{position:absolute;width:240px;height:240px;border-radius:50%;
  filter:blur(90px);opacity:.28;transition:background 1s;z-index:0}

.product-img-wrap{position:relative;z-index:2;
  animation:floatProd 5.5s ease-in-out infinite;
  filter:drop-shadow(0 32px 64px rgba(0,0,0,.65));
  transition:filter 1s}
@keyframes floatProd{0%,100%{transform:translateY(0) rotate(-1.5deg)}50%{transform:translateY(-18px) rotate(1.5deg)}}

.product-img-wrap img{height:340px;width:auto;object-fit:contain;
  transition:opacity .35s ease,transform .5s cubic-bezier(.34,1.3,.64,1)}

/* Floating info cards */
.fi-card{position:absolute;background:rgba(26,9,10,.82);backdrop-filter:blur(14px);
  border:1px solid rgba(212,175,55,.2);padding:10px 14px;border-radius:12px;z-index:3;
  min-width:110px}
.fi-label{font-size:9px;letter-spacing:.14em;text-transform:uppercase;color:rgba(255,255,255,.4);margin-bottom:3px}
.fi-val{font-family:var(--serif);font-size:13px;font-weight:600;color:var(--gold);transition:color .8s}
.fi-a{top:10%;right:-32px;opacity:0;animation:fadeLeft 1s 1.1s forwards}
.fi-b{bottom:18%;right:-32px;opacity:0;animation:fadeLeft 1s 1.3s forwards}
.fi-c{bottom:18%;left:-32px;opacity:0;animation:fadeRight 1s 1.5s forwards}

/* Product selector tabs */
.product-selector-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;width:100%;max-width:440px}
.selector-tab{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);
  border-radius:14px;padding:14px 10px;cursor:pointer;text-align:center;
  transition:var(--ease);display:flex;flex-direction:column;align-items:center;gap:8px}
.selector-tab:hover,.selector-tab.active{background:rgba(212,175,55,.12);border-color:var(--gold);transform:translateY(-3px)}
.tab-swatch{width:28px;height:28px;border-radius:50%;border:2px solid rgba(255,255,255,.2);
  transition:border-color .3s;flex-shrink:0}
.selector-tab.active .tab-swatch,.selector-tab:hover .tab-swatch{border-color:var(--gold)}
.tab-label{color:var(--white);font-size:11px;font-weight:500;opacity:.75}
.selector-tab.active .tab-label{opacity:1;color:var(--gold)}

/* Intensity row */
.intensity-row{display:flex;align-items:center;gap:12px;margin-top:4px;
  opacity:0;animation:fadeUp .9s 1s forwards}
.int-label{font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:rgba(255,255,255,.35)}
.int-dots{display:flex;gap:5px}
.int-dot{width:7px;height:7px;border-radius:50%;border:1px solid rgba(212,175,55,.35);background:transparent;transition:background .5s,border-color .5s}
.int-dot.on{background:var(--gold);border-color:var(--gold)}

/* scroll hint */
.scroll-hint{position:absolute;bottom:28px;left:50%;transform:translateX(-50%);
  display:flex;flex-direction:column;align-items:center;gap:6px;z-index:10;opacity:.38;
  animation:scrollBounce 2s ease-in-out infinite;color:var(--white)}
.scroll-hint span{font-size:9px;letter-spacing:.18em;text-transform:uppercase}
.sh-line{width:1px;height:32px;background:linear-gradient(to bottom,rgba(212,175,55,.8),transparent)}
@keyframes scrollBounce{0%,100%{transform:translateX(-50%) translateY(0)}50%{transform:translateX(-50%) translateY(7px)}}

/* FEATURES */
.features-strip{background:var(--dark);display:grid;grid-template-columns:repeat(4,1fr);
  border-top:1px solid rgba(212,175,55,.1);border-bottom:1px solid rgba(212,175,55,.1)}
.feat{padding:32px 28px;display:flex;align-items:flex-start;gap:14px;
  border-right:1px solid rgba(212,175,55,.08)}
.feat:last-child{border-right:none}
.feat-icon{width:36px;height:36px;flex-shrink:0;color:var(--gold);margin-top:2px}
.feat-title{font-size:13px;font-weight:600;color:var(--white);margin-bottom:4px;letter-spacing:.02em}
.feat-desc{font-size:12px;color:rgba(255,255,255,.42);line-height:1.65}

/* PRODUCTS SECTION */
.sec-products{padding:96px 6%;background:var(--cream)}
.sec-hdr{max-width:1200px;margin:0 auto 52px;display:flex;align-items:flex-end;justify-content:space-between}
.sec-eyebrow{font-size:11px;font-weight:600;letter-spacing:.2em;text-transform:uppercase;color:var(--burgundy);margin-bottom:10px}
.sec-title{font-family:var(--serif);font-size:clamp(1.8rem,3.2vw,2.6rem);font-weight:600;color:var(--dark);line-height:1.15}
.sec-title em{font-style:italic;font-weight:400;color:var(--burgundy)}
.see-all{font-size:12px;font-weight:600;letter-spacing:.12em;text-transform:uppercase;
  color:var(--burgundy);border-bottom:1px solid rgba(114,28,36,.3);padding-bottom:2px;transition:var(--ease)}
.see-all:hover{color:var(--dark);border-color:var(--dark)}
.prod-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;max-width:1200px;margin:0 auto}
.pc{background:var(--white);border-radius:16px;overflow:hidden;box-shadow:0 2px 16px rgba(0,0,0,.06);
  transition:transform .35s,box-shadow .35s;position:relative}
.pc:hover{transform:translateY(-8px);box-shadow:0 16px 40px rgba(0,0,0,.12)}
.pc-img{height:240px;display:flex;align-items:center;justify-content:center;padding:20px;position:relative;overflow:hidden}
.pc-img img{height:190px;width:auto;object-fit:contain;
  filter:drop-shadow(0 12px 24px rgba(0,0,0,.2));transition:transform .45s cubic-bezier(.34,1.3,.64,1)}
.pc:hover .pc-img img{transform:scale(1.08) translateY(-6px)}
.pc-badge{position:absolute;top:12px;left:12px;font-size:10px;letter-spacing:.1em;
  text-transform:uppercase;padding:4px 10px;border-radius:100px;font-weight:600}
.pc-body{padding:18px}
.pc-origin{font-size:10px;letter-spacing:.14em;text-transform:uppercase;font-weight:600;margin-bottom:4px}
.pc-name{font-family:var(--serif);font-size:1.25rem;font-weight:600;color:var(--dark);margin-bottom:4px;line-height:1.2}
.pc-notes{font-size:12px;color:rgba(45,45,45,.5);line-height:1.6;margin-bottom:14px}
.pc-foot{display:flex;align-items:center;justify-content:space-between;
  border-top:1px solid rgba(0,0,0,.07);padding-top:12px}
.pc-price{font-family:var(--serif);font-size:1.4rem;font-weight:700;color:var(--dark)}
.pc-price sub{font-size:.7rem;font-weight:400;color:rgba(45,45,45,.45);font-family:var(--sans)}
.pc-atc{width:36px;height:36px;border-radius:50%;border:1px solid;background:none;
  font-size:1.1rem;display:flex;align-items:center;justify-content:center;
  transition:background .25s,color .25s,transform .2s}
.pc-atc:hover{transform:scale(1.12)}

/* QUOTE */
.quote-sec{background:var(--dark);padding:88px 6%;text-align:center;
  border-top:1px solid rgba(212,175,55,.1);border-bottom:1px solid rgba(212,175,55,.1)}
.q-mark{font-family:var(--serif);font-size:5rem;line-height:.4;color:rgba(212,175,55,.2);display:block;margin-bottom:24px}
.q-text{font-family:var(--serif);font-size:clamp(1.4rem,2.8vw,2.2rem);font-style:italic;
  font-weight:400;color:var(--white);max-width:700px;margin:0 auto 20px;line-height:1.5}
.q-author{font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:var(--gold)}

/* STORY */
.story-sec{display:grid;grid-template-columns:1fr 1fr}
.story-left{background:var(--cream);padding:96px 6%;display:flex;flex-direction:column;justify-content:center}
.story-right{background:radial-gradient(circle at 40% 60%,var(--burgundy),var(--dark) 70%);
  display:flex;align-items:center;justify-content:center;padding:72px 5%;position:relative;overflow:hidden}
.story-bg-num{position:absolute;font-family:var(--serif);font-size:13rem;font-weight:700;
  color:rgba(212,175,55,.07);line-height:1;pointer-events:none}
.story-inner{position:relative;z-index:1;text-align:center;color:var(--white)}
.story-stat{font-family:var(--serif);font-size:5rem;font-weight:700;color:var(--gold)}
.story-lbl{font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:rgba(255,255,255,.45);margin-top:8px}
.st-eyebrow{font-size:11px;font-weight:600;letter-spacing:.2em;text-transform:uppercase;
  color:var(--burgundy);margin-bottom:14px;display:flex;align-items:center;gap:10px}
.st-eyebrow::before{content:'';width:24px;height:1px;background:var(--burgundy)}
.st-title{font-family:var(--serif);font-size:clamp(1.8rem,3vw,2.5rem);font-weight:600;
  color:var(--dark);line-height:1.2;margin-bottom:16px}
.st-title em{font-style:italic;font-weight:400;color:var(--burgundy)}
.st-text{font-size:14px;line-height:1.85;color:rgba(45,45,45,.6);font-weight:300;max-width:440px;margin-bottom:28px}

/* Toast */
.toast{position:fixed;bottom:7rem;right:2.5rem;z-index:600;background:var(--burgundy);color:var(--white);
  padding:12px 20px;font-size:13px;font-weight:600;letter-spacing:.04em;border-radius:8px;
  transform:translateY(16px);opacity:0;pointer-events:none;
  transition:transform .4s cubic-bezier(.34,1.4,.64,1),opacity .3s}
.toast.on{transform:translateY(0);opacity:1}

@keyframes fadeUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeLeft{from{opacity:0;transform:translateX(16px)}to{opacity:1;transform:translateX(0)}}
@keyframes fadeRight{from{opacity:0;transform:translateX(-16px)}to{opacity:1;transform:translateX(0)}}

</style>
</head>
