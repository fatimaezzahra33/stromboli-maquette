<script>
const obs=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting)e.target.classList.add('vis')}),{threshold:.1});
document.querySelectorAll('.reveal').forEach(el=>obs.observe(el));
</script>
<script>
const IMGS = {
  orange: "data:image/jpeg;base64,",
  dore:   "data:image/jpeg;base64,",
  rouge:  "data:image/jpeg;base64,",
  blue:   "data:image/jpeg;base64,"
};
const P = [
  {id:'orange',name:'Expresso Orange',origin:'Éthiopie · Sidamo',roast:'Légère-Moyenne',notes:['Agrumes','Miel','Fleur'],intensity:3,price:'32€',img:IMGS.orange,swatch:'#c8580e',accent:'#d4701a',bg:'radial-gradient(circle at 60% 40%,rgba(200,80,10,.38) 0%,rgba(26,9,10,1) 65%)',badgeBg:'rgba(210,100,20,.12)',badgeC:'#d4701a',badgeTxt:'Café Naturel'},
  {id:'dore',name:'Expresso Doré',origin:'Colombie · Huila',roast:'Moyenne',notes:['Caramel','Noisette','Chocolat'],intensity:4,price:'38€',img:IMGS.dore,swatch:'#c8923a',accent:'#c8923a',bg:'radial-gradient(circle at 60% 40%,rgba(180,130,20,.32) 0%,rgba(26,9,10,1) 65%)',badgeBg:'rgba(200,146,58,.12)',badgeC:'#b8820a',badgeTxt:'Prestige'},
  {id:'rouge',name:'Expresso Rouge',origin:'Brésil · Cerrado',roast:'Forte',notes:['Épices','Cerise','Cacao'],intensity:5,price:'34€',img:IMGS.rouge,swatch:'#a81818',accent:'#c03030',bg:'radial-gradient(circle at 60% 40%,rgba(160,20,20,.4) 0%,rgba(26,9,10,1) 65%)',badgeBg:'rgba(180,30,30,.12)',badgeC:'#c03030',badgeTxt:'Intense'},
  {id:'blue',name:'Expresso Blue',origin:'Guatemala · Antigua',roast:'Moyenne',notes:['Vanille','Amande','Caramel'],intensity:3,price:'34€',img:IMGS.blue,swatch:'#2050b8',accent:'#3060c8',bg:'radial-gradient(circle at 60% 40%,rgba(30,60,180,.28) 0%,rgba(26,9,10,1) 65%)',badgeBg:'rgba(40,80,200,.12)',badgeC:'#3060c8',badgeTxt:'Équilibré'}
];
let cur=0,cartN=0;

// Build tabs
const tabsEl=document.getElementById('tabs');
P.forEach((p,i)=>{
  const d=document.createElement('div');
  d.className='selector-tab'+(i===0?' active':'');
  d.innerHTML=`<div class="tab-swatch" style="background:${p.swatch}40;border-color:${p.swatch}60"></div><span class="tab-label">${p.name.replace('Expresso ','')}</span>`;
  d.addEventListener('click',()=>sel(i));
  tabsEl.appendChild(d);
});

// Build grid add-to-cart
document.querySelectorAll('.pc-atc').forEach(btn=>{
  btn.addEventListener('click',()=>{
    const i=+btn.dataset.idx, p=P[i];
    cartN++;showToast('🛒 '+p.name+' ajouté');
    btn.style.background=p.accent;btn.style.color='#fff';btn.style.transform='scale(1.35)';
    setTimeout(()=>{btn.style.background='';btn.style.color=p.accent;btn.style.transform=''},420);
  });
});

function sel(idx){
  cur=idx;const p=P[idx];
  document.querySelectorAll('.selector-tab').forEach((t,i)=>t.classList.toggle('active',i===idx));
  document.querySelector('.hero-section').style.background=p.bg;
  document.getElementById('pglow').style.background=p.accent;
  const img=document.getElementById('pimg');
  img.style.opacity='0';img.style.transform='scale(.88) translateY(12px)';
  setTimeout(()=>{img.src=p.img;img.style.transition='opacity .4s,transform .5s cubic-bezier(.34,1.3,.64,1)';img.style.opacity='1';img.style.transform='scale(1) translateY(0)';},320);
  document.getElementById('fiorig').textContent=p.origin;
  document.getElementById('firoast').textContent=p.roast;
  document.getElementById('hprice').innerHTML=p.price+'<sub>/250g</sub>';
  document.getElementById('hprice').style.color=p.accent;
  // pills
  const pills=document.getElementById('pills');pills.innerHTML='';
  p.notes.forEach(n=>{const s=document.createElement('span');s.className='tag-pill';s.textContent=n;s.style.borderColor=p.accent+'55';s.style.color=p.accent+'cc';pills.appendChild(s);});
  // dots
  const dots=document.getElementById('idots');dots.innerHTML='';
  for(let i=0;i<5;i++){const d=document.createElement('div');d.className='int-dot'+(i<p.intensity?' on':'');if(i<p.intensity){d.style.background=p.accent;d.style.borderColor=p.accent;}dots.appendChild(d);}
  document.documentElement.style.setProperty('--gold',p.accent);
}

function showToast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('on');clearTimeout(t._t);t._t=setTimeout(()=>t.classList.remove('on'),2600);}
sel(0);
</script>
